{
  "info": {
    "name": "Investigation System",
    "_postman_id": "201f4b7e-fd69-4dc4-8980-d2ea885cd8f7",
    "description": "Full test suite for all 6 microservices. \n\nSETUP:\n1. Set collection variable `keycloak_url` = http://localhost:8080\n2. Run '0. Get Token' first — it auto-saves the token.\n3. All other requests use {{token}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:9000" },
    { "key": "keycloak_url",  "value": "http://localhost:8080" },
    { "key": "realm",         "value": "spring" },
    { "key": "client_id",     "value": "microservices" },
    { "key": "username",      "value": "admin_user" },
    { "key": "password",      "value": "hello" },
    { "key": "token",         "value": "" },
    { "key": "case_id",       "value": "1" },
    { "key": "task_id",       "value": "1" },
    { "key": "evidence_id",   "value": "1" },
    { "key": "person_id",     "value": "1" },
    { "key": "notification_id","value": "1" }
  ],
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    pm.test('Token obtained', () => pm.response.to.have.status(200));",
                  "} else {",
                  "    pm.test('Token NOT obtained — check username/password/client_id', () => false);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id",  "value": "{{client_id}}" },
                { "key": "username",   "value": "{{username}}" },
                { "key": "password",   "value": "{{password}}" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            }
          }
        }
      ]
    },
    {
