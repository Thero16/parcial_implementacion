              "raw": "{\n  \"title\": \"Murder at the Mansion\",\n  \"description\": \"A suspicious death was reported at Blackwood Manor.\",\n  \"status\": \"OPEN\",\n  \"priority\": \"HIGH\",\n  \"assignedDetective\": \"detective1\",\n  \"createdAt\": \"2026-04-07T10:00:00\"\n}"
            },
